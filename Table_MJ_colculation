#include <iostream>
#include <cmath>
using namespace std;

class Table 
{
protected:
    double area=0;
public:
    virtual void colculation() {}
    void display1() {
        cout << "面积是：" << area << endl;
    }
};
class Round : public Table
{
private:
    double R;
public:
    Round(double a) {
        R = a;
    }

    void colculation() {
        area = 3.14159 * R * R;
    }

    void display2() {
        cout << "圆桌" << endl;

    };
};
class Rect : public Table 
{
private:
    double L, W;
public:
    Rect(double a, double b) {
        L = a;
        W = b;
    }

    void colculation() {
        area = L * W;
    }

    void display2() {
        cout << "矩形桌" << endl;
    }
};
class Triangle : public Table 
{
private:
    double C1, C2, C3;
public:
    Triangle(double a, double b, double c) {
        C1 = a;
        C2 = b;
        C3 = c;
    }
    void colculation() {
        double p = (C1 + C2 + C3) / 2;
        area = sqrt(p * (p - C1) * (p - C2) * (p - C3));
    }

    void display2() {
        if (C1 + C2 > C3 && C1 + C3 > C2 && C2 + C3 > C1)
        {
            cout << "三角桌" << endl;
        }
        else
        {
            cout << "无法构成三角形" << endl;
        }
    }

};
int main()
{
    double a, b, c;
    cout << "输入数据，输入0结束输入：" << endl;
    cin >> a;
    if (a == 0)
    {
        cout << "至少输入一个数据" << endl;
    }
    else
    {
        cin >> b;
        if (b == 0)
        {
            Round S1(a);
            S1.colculation();
            S1.display2();
            S1.display1();
        }
        else
        {
            cin >> c;
            if (c == 0)
            {
                Rect S1(a, b);
                S1.colculation();
                S1.display2();
                S1.display1();
            }
            else
            {
                Triangle S1(a, b, c);
                S1.colculation();
                S1.display2();
                S1.display1();
            }
        }

    }
    
    return 0;
}
